// LingoPeak Database Schema
// Run `npx prisma migrate dev --name init` after setting DATABASE_URL in .env

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum SubscriptionTier {
  FREE
  STARTER
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

enum ConversationStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum MessageRole {
  USER
  ASSISTANT
}

enum ProficiencyLevel {
  BEGINNER
  ELEMENTARY
  INTERMEDIATE
  UPPER_INTERMEDIATE
  ADVANCED
  FLUENT
}

// ============================================================
// CORE USER MODELS
// ============================================================

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  fullName      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastLoginAt   DateTime?
  emailVerified Boolean  @default(false)
  isActive      Boolean  @default(true)

  // Relations
  subscription      Subscription?
  learningProfiles   LearningProfile[]
  conversations      Conversation[]
  vocabularyProgress VocabularyProgress[]
  usageRecords       UsageRecord[]
  achievements       UserAchievement[]
  refreshTokens      RefreshToken[]

  @@index([email])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  @@index([userId])
}

// One per language a user is learning (a user can learn multiple languages)
model LearningProfile {
  id                String           @id @default(uuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  languageId        String
  language          Language         @relation(fields: [languageId], references: [id])
  proficiencyLevel  ProficiencyLevel @default(BEGINNER)
  goalDescription   String?
  dailyGoalMinutes  Int              @default(15)
  currentStreak     Int              @default(0)
  longestStreak      Int              @default(0)
  lastPracticedAt    DateTime?
  totalMinutesSpent  Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  conversations      Conversation[]
  vocabularyProgress VocabularyProgress[]

  @@unique([userId, languageId])
  @@index([userId])
}

model Language {
  id            String   @id @default(uuid())
  code          String   @unique // e.g. "es", "fr", "de", "ja", "zh", "it"
  name          String   // e.g. "Spanish"
  nativeName    String   // e.g. "Espa\u00f1ol"
  flagEmoji     String?
  isActive      Boolean  @default(true)

  learningProfiles  LearningProfile[]
  vocabularyItems   VocabularyItem[]

  @@index([code])
}

// ============================================================
// SUBSCRIPTION & BILLING
// ============================================================

model Subscription {
  id                     String             @id @default(uuid())
  userId                 String             @unique
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier                   SubscriptionTier   @default(FREE)
  status                 SubscriptionStatus @default(TRIALING)
  billingInterval        BillingInterval    @default(MONTHLY)
  razorpayCustomerId     String?            @unique
  razorpaySubscriptionId String?            @unique
  trialEndsAt            DateTime?
  currentPeriodStart     DateTime           @default(now())
  currentPeriodEnd       DateTime?
  canceledAt             DateTime?
  monthlyMinutesLimit    Int                @default(50) // -1 means unlimited
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@index([userId])
  @@index([razorpayCustomerId])
}

// Tracks AI conversation minutes used in the current billing cycle (for metering Starter plan limits)
model UsageRecord {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodStart   DateTime
  periodEnd     DateTime
  minutesUsed   Int      @default(0)
  messagesCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, periodStart])
  @@index([userId])
}

// ============================================================
// AI CONVERSATION / TUTORING
// ============================================================

model Conversation {
  id                String             @id @default(uuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningProfileId String
  learningProfile   LearningProfile    @relation(fields: [learningProfileId], references: [id], onDelete: Cascade)
  topic             String?            // e.g. "Ordering food at a restaurant"
  status            ConversationStatus @default(ACTIVE)
  durationSeconds   Int                @default(0)
  startedAt         DateTime           @default(now())
  endedAt           DateTime?

  messages Message[]

  @@index([userId])
  @@index([learningProfileId])
}

model Message {
  id              String       @id @default(uuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            MessageRole
  content         String       @db.Text
  // Pronunciation/grammar feedback attached to a user message, stored as JSON
  // e.g. { "corrections": [...], "pronunciationScore": 82 }
  feedback        Json?
  createdAt       DateTime     @default(now())

  @@index([conversationId])
}

// ============================================================
// VOCABULARY & PROGRESS
// ============================================================

model VocabularyItem {
  id           String   @id @default(uuid())
  languageId   String
  language     Language @relation(fields: [languageId], references: [id])
  word         String
  translation  String
  exampleSentence String?
  difficultyLevel ProficiencyLevel @default(BEGINNER)
  createdAt    DateTime @default(now())

  progress VocabularyProgress[]

  @@index([languageId])
  @@index([word])
}

// Spaced-repetition tracking per user, per vocabulary item
model VocabularyProgress {
  id                String          @id @default(uuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningProfileId String
  learningProfile   LearningProfile @relation(fields: [learningProfileId], references: [id], onDelete: Cascade)
  vocabularyItemId  String
  vocabularyItem    VocabularyItem  @relation(fields: [vocabularyItemId], references: [id])
  timesReviewed     Int             @default(0)
  timesCorrect      Int             @default(0)
  nextReviewAt      DateTime        @default(now())
  // Spaced repetition interval in days (e.g. SM-2 style algorithm)
  intervalDays      Int             @default(1)
  easeFactor        Float           @default(2.5)
  masteredAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([userId, vocabularyItemId])
  @@index([userId])
  @@index([nextReviewAt])
}

// ============================================================
// GAMIFICATION
// ============================================================

model Achievement {
  id          String @id @default(uuid())
  code        String @unique // e.g. "first_conversation", "7_day_streak"
  name        String
  description String
  iconEmoji   String?

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  earnedAt      DateTime    @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}
